<?xml version="1.0" encoding="utf-8"?>
<flyouts:DesktopFlyout
    x:Class="Karen.Views.KarenPopup"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:flyouts="using:DesktopFlyouts"
    FlyoutWidth="360"
    FlyoutHeight="Auto"
    Placement="BottomRight"
    PopupDirection="Vertical"
    mc:Ignorable="d">

    <flyouts:DesktopFlyoutIsland IslandHeight="Auto">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="1" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="1" />
                <RowDefinition Height="46" />
            </Grid.RowDefinitions>

            <Border Grid.RowSpan="3" Background="{ThemeResource FlyoutOverlayBackgroundBrush}" />
            <Border Grid.Row="1" Background="{ThemeResource FlyoutSeparatorPrimaryBackgroundBrush}" />
            <Border Grid.Row="3" Background="{ThemeResource FlyoutSeparatorSecondaryBackgroundBrush}" />

            <StackPanel Padding="16">
                <Image Width="192" Source="/Assets/logo.png" Margin="0,-26,0,-12"/>
                <TextBlock FontWeight="Bold" Text="✌️ LANraragi is running" HorizontalAlignment="Center" Visibility="{x:Bind Server.IsRunning, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" />
                <TextBlock FontWeight="Bold" Text="❌ LANraragi is stopped" HorizontalAlignment="Center" Visibility="{x:Bind Server.IsRunning, Mode=OneWay, Converter={StaticResource NegateBoolToVisibilityConverter}}" />
                <TextBlock FontSize="13" TextAlignment="Center" TextWrapping="Wrap" Text="{x:Bind Server.Version}" />
            </StackPanel>

            <StackPanel Grid.Row="2" Padding="16" Spacing="12" Orientation="Horizontal" HorizontalAlignment="Center">
                <StackPanel.Resources>
                    <Style TargetType="StackPanel">
                        <Setter Property="Spacing" Value="12" />
                    </Style>
                    <Style TargetType="Button" BasedOn="{StaticResource DefaultButtonStyle}">
                        <Setter Property="Width" Value="96" />
                        <Setter Property="Height" Value="48" />
                    </Style>
                    <Style TargetType="ToggleButton" BasedOn="{StaticResource DefaultToggleButtonStyle}">
                        <Setter Property="Width" Value="96" />
                        <Setter Property="Height" Value="48" />
                    </Style>
                    <Style TargetType="TextBlock" BasedOn="{StaticResource CaptionTextBlockStyle}">
                        <Setter Property="HorizontalAlignment" Value="Center" />
                        <Setter Property="TextLineBounds" Value="TrimToCapHeight" />
                    </Style>
                    <Style TargetType="Viewbox">
                        <Setter Property="MaxHeight" Value="16" />
                    </Style>
                </StackPanel.Resources>
                <StackPanel>
                    <ToggleButton x:Name="StartStopButtom" IsChecked="{x:Bind Server.IsRunning, Mode=OneWay}" IsEnabled="{x:Bind Server.CanRun}" Command="{x:Bind Data.StartStopCommand}" CommandParameter="{x:Bind StartStopButtom.IsChecked, Mode=OneWay}">
                        <Viewbox>
                            <FontIcon Glyph="{x:Bind Server.IsRunning, Mode=OneWay, Converter={StaticResource BoolToAppIconConverter}}" />
                        </Viewbox>
                    </ToggleButton>
                    <TextBlock Text="{x:Bind Server.IsRunning, Mode=OneWay, Converter={StaticResource BoolToAppStateConverter}}" />
                </StackPanel>
                <StackPanel>
                    <Button Command="{x:Bind Data.OpenClientCommand}" IsEnabled="{x:Bind Server.IsRunning, Mode=OneWay}">
                        <Viewbox>
                            <FontIcon Glyph="&#xE8A7;" />
                        </Viewbox>
                    </Button>
                    <TextBlock Text="Open client" />
                </StackPanel>
            </StackPanel>

            <Grid Grid.Row="4" Padding="12,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Grid>
                </Grid>
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <StackPanel.Resources>
                        <Style TargetType="Button" BasedOn="{StaticResource SubtleButtonStyle}">
                            <Setter Property="Width" Value="36" />
                            <Setter Property="Height" Value="36" />
                            <Setter Property="Padding" Value="10" />
                            <Setter Property="BorderThickness" Value="0" />
                        </Style>
                    </StackPanel.Resources>
                    <Button Command="{x:Bind Data.OpenAppFolderCommand}" Visibility="{x:Bind Server.IsRunning, Mode=OneWay, Converter={StaticResource NegateBoolToVisibilityConverter}}" ToolTipService.ToolTip="Open app folder">
                        <Viewbox>
                            <FontIcon Glyph="&#xE838;" />
                        </Viewbox>
                    </Button>
                    <Button Command="{x:Bind Data.ShowConsoleCommand}" ToolTipService.ToolTip="Log console">
                        <Viewbox>
                            <FontIcon Glyph="&#xE8FD;" />
                        </Viewbox>
                    </Button>
                    <Button Command="{x:Bind Data.OpenSettingsCommand}" ToolTipService.ToolTip="Settings">
                        <Viewbox>
                            <FontIcon Glyph="&#xE713;" />
                        </Viewbox>
                    </Button>
                    <Button Tapped="Button_Tapped" ToolTipService.ToolTip="Quit">
                        <Viewbox>
                            <FontIcon Glyph="&#xE7E8;" />
                        </Viewbox>
                    </Button>
                </StackPanel>
            </Grid>
        </Grid>
    </flyouts:DesktopFlyoutIsland>
</flyouts:DesktopFlyout>
